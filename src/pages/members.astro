---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
---
<BaseLayout title="Members" description="Members-only area (coming soon).">
  <PageHeader title="Members Area" sub="Coming soon." />
  <div class="wrap prose">
    <p>
      A members-only section is planned for the club website — a place for meeting minutes,
      rosters, and other resources for current members.
    </p>
    <p>
      It isn't available yet. In the meantime, questions can go to
      <a href="/contact">the club</a>.
    </p>
  </div>
</BaseLayout>
