---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';

const entry = await getEntry('pages', 'membership');
const { Content } = await render(entry!);
---
<BaseLayout title="Membership" description={entry!.data.description}>
  <PageHeader title="Membership" sub="Dues are $25 per year and support the club's repeaters and activities." />
  <div class="wrap">
    <div class="prose">
      <Content />
      <p>
        <a class="btn" href="/files/Membership-form.pdf">Download the membership form (PDF)</a>
      </p>
    </div>
  </div>
</BaseLayout>
