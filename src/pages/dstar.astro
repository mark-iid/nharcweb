---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import padstar from '../data/padstar.json';

const entry = await getEntry('pages', 'dstar');
const { Content } = await render(entry!);
---
<BaseLayout title="D-STAR" description={entry!.data.description}>
  <PageHeader title="D-STAR" sub="Pittsburgh's original D-STAR digital voice repeaters." />
  <div class="wrap">
    <div class="prose">
      <Content />
    </div>

    <h2>Pennsylvania D-STAR Repeaters</h2>
    <p>A reference list of D-STAR repeaters across the state.</p>
    <div class="table-scroll">
      <table class="data">
        <thead>
          <tr><th>Frequency</th><th>Duplex</th><th>Offset</th><th>Callsigns</th><th>Location</th></tr>
        </thead>
        <tbody>
          {padstar.map((r) => (
            <tr>
              <td class="freq">{r.frequency}</td>
              <td>{r.duplex}</td>
              <td>{r.offset}</td>
              <td class="callsign">{r.callsigns}</td>
              <td>{r.location}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</BaseLayout>
