---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';

const entry = await getEntry('pages', 've-testing');
const { Content } = await render(entry!);
---
<BaseLayout title="License Testing" description={entry!.data.description}>
  <PageHeader title="License Testing" sub="VE exam sessions on the second Saturday of every month." />
  <div class="wrap">
    <div class="prose">
      <Content />
    </div>
  </div>
</BaseLayout>
