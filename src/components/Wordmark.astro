---
// Modernized NHARC wordmark: bold letterforms with a spectrum gradient that
// echoes the club's classic multicolor logo, tuned to the site's signal theme.
interface Props { height?: number; }
const { height = 30 } = Astro.props;
const ratio = 300 / 64;
const width = Math.round(height * ratio);
const gid = 'nharcGrad';
---
<svg
  class="wordmark"
  width={width}
  height={height}
  viewBox="0 0 300 64"
  role="img"
  aria-label="NHARC"
  xmlns="http://www.w3.org/2000/svg"
>
  <defs>
    <linearGradient id={gid} x1="0" y1="0" x2="1" y2="0.15">
      <stop offset="0" stop-color="#8a6bff" />
      <stop offset="0.34" stop-color="#24d3e6" />
      <stop offset="0.68" stop-color="#ff8a3d" />
      <stop offset="1" stop-color="#ffcc33" />
    </linearGradient>
  </defs>
  <text
    x="1"
    y="51"
    textLength="298"
    lengthAdjust="spacingAndGlyphs"
    font-family="'Helvetica Neue', Arial, sans-serif"
    font-weight="800"
    font-size="60"
    fill={`url(#${gid})`}
  >NHARC</text>
</svg>
