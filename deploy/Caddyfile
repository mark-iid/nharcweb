# NHARC website — Caddy config.
# Installed on the server at /etc/caddy/Caddyfile.
# Caddy obtains and renews a Let's Encrypt certificate automatically.
#
# At DNS cutover, add nharc.org and www.nharc.org (see HANDOFF.md).

newweb.nharc.org {
	root * /var/www/nharc
	encode zstd gzip

	# CMS "Sign In with GitHub" OAuth relay (nharc-oauth.service on :8402).
	handle /auth* {
		reverse_proxy 127.0.0.1:8402
	}
	handle /callback* {
		reverse_proxy 127.0.0.1:8402
	}

	# Static site.
	handle {
		# Long-cache the immutable hashed assets Astro emits under /_astro/.
		@astro path /_astro/*
		header @astro Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	# Friendly 404 page.
	handle_errors {
		@notfound expression {http.error.status_code} == 404
		rewrite @notfound /404.html
		file_server
	}
}

# Access + runtime logs go to journald: `journalctl -u caddy`.
